rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Pacientes — solo usuarios autenticados (web)
    match /pacientes/{docId} {
      allow read, write: if request.auth != null;
    }

    // Sesiones — autenticados pueden leer/escribir, Godot escribe sin auth
    match /sesiones/{docId} {
      allow read: if request.auth != null;
      allow write: if true;  // Godot escribe resultados sin autenticación
    }

    // Sesión activa — la web escribe, Godot lee (sin auth desde las gafas)
    match /sesion_activa/{docId} {
      allow read: if true;   // Godot lee sin autenticación
      allow write: if request.auth != null;  // Solo la web escribe
    }
  }
}
