rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Pacientes — solo usuarios autenticados (web)
    match /pacientes/{docId} {
      allow read, write: if request.auth != null;
    }

    // Sesiones — Godot escribe sin auth, web lee con auth
    match /sesiones/{docId} {
      allow read: if request.auth != null;
      allow write: if true;
    }

    // Sesión activa — web escribe (auth), Godot APK lee sin auth
    match /sesion_activa/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Dispositivos — web crea/elimina (auth), Godot APK actualiza sin auth
    match /dispositivos/{code} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if true;   // Godot vincula y actualiza estado
      allow delete: if request.auth != null;
    }
  }
}
